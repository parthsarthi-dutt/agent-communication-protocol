# ── LLM Provider Configuration ─────────────────────────────────────────
# Set the default provider (used by evaluate.py and as fallback)

# Option 1: Google Gemini (Free tier — recommended)
LLM_PROVIDER=gemini
GOOGLE_API_KEY=your-google-api-key-here

# Option 2: Groq (Free tier — used for Auditor agent in demo)
GROQ_API_KEY=your-groq-api-key-here

# Option 3: Ollama (Local, fully free, no API key needed)
# LLM_PROVIDER=ollama
# OLLAMA_MODEL=qwen2.5:7b-instruct-q4_K_M
# OLLAMA_BASE_URL=http://localhost:11434
